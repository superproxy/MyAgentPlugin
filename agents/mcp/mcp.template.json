{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./"
      ],
      "env": {}
    },
    "12306-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "12306-mcp"
      ],
      "disabled": true
    },
    "amap-maps-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
      },
      "disabled": false
    },
    "wecom": {
      "command": "uvx",
      "args": [
        "wecom-bot-mcp-server"
      ],
      "env": {
        "WECOM_WEBHOOK_URL": "${WECOM_WEBHOOK_URL}"
      },
      "disabled": true
    },
    "BOSS直聘": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-boss-zp"
      ],
      "env": {
        "COOKIE": "${BOSS_COOKIE}",
        "BST": "${BOSS_BST}"
      },
      "disabled": true
    },
    "playwright": {
      "name": "playwright",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "disabled": false
    },
    "tavily-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "DEFAULT_PARAMETERS": "{\"include_images\": true, \"max_results\": 15, \"search_depth\": \"advanced\"}"
      },
      "disabled": false
    },
    "firecrawl-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "disabled": true
    },
    "arxiv-paper-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@langgpt/arxiv-paper-mcp@latest"
      ],
      "env": {},
      "disabled": false
    },
    "zread": {
      "type": "streamableHttp",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer ${ZREAD_API_KEY}"
      },
      "disabled": false
    },
    "openaiDeveloperDocs": {
      "url": "https://developers.openai.com/mcp",
      "disabled": false
    },
    "yuque-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "yuque-mcp",
        "start",
        "--token=${YUQUE_TOKEN}",
        "--client=vscode"
      ],
      "env": {
        "YUQUE_TOKEN": "${YUQUE_TOKEN}"
      },
      "disabled": false
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      },
      "disabled": true
    },
    "mastergo": {
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/vibe-mcp",
        "--url=http://localhost:50678"
      ],
      "disabled": false
    },
    "mastergo-magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/magic-mcp",
        "--token=${MASTERGO_MAGIC_TOKEN}",
        "--url=https://mastergo.com"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/"
      },
      "disabled": false
    },
    "Redis": {
      "command": "redis",
      "args": [
        "-e",
        "REDIS_URL=\"redis://localhost:6379\"",
        "--",
        "npx",
        "@modelcontextprotocol/server-redis"
      ],
      "disabled": true
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "disabled": false
    },
    "my-rag": {
      "command": "uvx",
      "args": [
        "mcp-rag",
        "serve"
      ],
      "env": {
        "OPENAI_API_KEY": "${EMBEDDING_API_KEY}",
        "OPENAI_BASE": "${EMBEDDING_BASE_URL}",
        "OPENAI_EMBEDDING_MODEL": "${EMBEDDING_MODEL}"
      },
      "type": "streamableHttp",
      "url": "http://localhost:8060/mcp",
      "startupTimeout": 10000,
      "disabled": true
    },
    "volc-speech": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp-server-speech",
        "mcp-server-speech"
      ],
      "env": {
        "VOLC_APPID": "${TTS_VOLCENGINE_APPID}",
        "VOLC_TOKEN": "${TTS_VOLCENGINE_TOKEN}",
        "VOLC_CLUSTER": "${TTS_VOLCENGINE_CLUSTER}",
        "VOLC_VOICE_TYPE": "${TTS_VOLCENGINE_VOICE_TYPE}"
      },
      "disabled": true
    },
    "seedance-mcp-server": {
      "command": "uvx",
      "args": [
        "seedance-mcp-server"
      ],
      "env": {
        "DOUBAO_BASE_URL": "${VISION_VOLCENGINE_BASE_URL}",
        "DOUBAO_API_KEY": "${VISION_VOLCENGINE_API_KEY}",
        "DOUBAO_MODEL": "${VISION_VOLCENGINE_MODEL}"
      },
      "disabled": false
    },
    "elevenlabs": {
      "command": "uvx",
      "args": [
        "elevenlabs-mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${TTS_ELEVENLABS_API_KEY}"
      },
      "disabled": false
    },
    "undoom-douyin-data-analysis": {
      "command": "uvx",
      "args": [
        "--index-url",
        "https://pypi.tuna.tsinghua.edu.cn/simple",
        "--from",
        "undoom-douyin-data-analysis",
        "undoom-douyin-mcp"
      ],
      "disabled": "true"
    },
    "open-computer-use": {
      "name": "open-computer-use",
      "command": "npx",
      "args": [
        "-y",
        "open-computer-use",
        "mcp"
      ]
    }
  }
}